#!/bin/sh
set -e

APP_DIR="/opt/wold-server/app"
VENV="/opt/wold-server/venv"

ENV_FILE="/etc/wold-server.conf"
if [ -f "$ENV_FILE" ]; then
    . "$ENV_FILE"
fi

export DJANGO_SETTINGS_MODULE="${DJANGO_SETTINGS_MODULE:-core.settings}"
export DEBUG=False

PYTHON_EXEC="$VENV/bin/python"

if [ ! -x "$PYTHON_EXEC" ]; then
    echo "ERROR: Python venv not found at $PYTHON_EXEC"
    exit 127
fi

cd "$APP_DIR"

CMD="${1:-run}"
shift || true

case "$CMD" in

    run)
        exec "$VENV/bin/daphne" \
            -b 127.0.0.1 \
            -p 8000 \
            core.asgi:application
        ;;

    createsuperuser)
        exec "$PYTHON_EXEC" manage.py createsuperuser
        ;;

    *)
        echo "Usage: woldctl {run|createsuperuser}"
        exit 2
        ;;
esac